# Doctigo Insight — Environment Variables
# Copy this to .env and fill your values. NEVER commit .env to git.

# Your Anthropic API key — get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server port (Vercel sets this automatically)
PORT=3000
NODE_ENV=development

# CORS — in production set this to your Vercel URL
ALLOWED_ORIGIN=*
